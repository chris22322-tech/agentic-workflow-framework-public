# Environment Variables — Starter Project
# =========================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit .env to version control — it's in .gitignore.
# In production, use your platform's secrets manager instead.
#
# Methodology reference:
#   - Stage 5: Build → Production Secrets warning

# ── LLM Provider ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Data Source APIs ──────────────────────────────────────────────────
# Add one entry per tool / data source from your Stage 3 Data Inventory.
# Example:
EXAMPLE_API_URL=https://api.example.com
EXAMPLE_API_KEY=your-api-key-here

# ── Optional ──────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
